# Environment Configuration for Boiler Alarm System
# Copy this file to .env and update with your actual values

# GPIO Configuration
ALARM_GPIO_PIN=18
GPIO_PULL_UP=True
# ALARM_ACTIVE_STATE: Set based on your optocoupler configuration
# For 12-24V systems with optocoupler: typically LOW when alarm is active
ALARM_ACTIVE_STATE=LOW

# Email/SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True

# Alert Configuration
ALERT_SENDER=your-email@gmail.com
# Comma-separated list of email addresses or phone numbers
ALERT_RECIPIENTS=super@building.com,5551234567@vtext.com,manager@property.com

# Building Information
BUILDING_NAME=Main Building
BUILDING_ADDRESS=123 Main St, City, State 12345
SUPER_NAME=John Smith

# Monitoring Configuration
CHECK_INTERVAL=0.1
DEBOUNCE_TIME=2.0
ALERT_COOLDOWN=300

# System Configuration
SIMULATION_MODE=False
LOG_LEVEL=INFO